# ── Django ──
SECRET_KEY=genera-una-clave-larga-y-secreta
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# ── Base de datos ──
# En local se usa SQLite automáticamente si no defines DATABASE_URL.
# Railway inyecta DATABASE_URL al añadir el plugin de PostgreSQL.
DATABASE_URL=

# ── Cloudflare R2 (archivos / PDFs) — Fase 3 ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Email (recuperación de contraseña, envío de cupón) ──
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
